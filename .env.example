# このファイルをコピーして .env.local を作成し、値を埋める（.env* はコミット禁止）
# 実際の秘密情報は Vercel の環境変数に設定する。

# --- Auth.js (Google ログイン) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# ログインを許可する家族のメール（カンマ区切り allowlist）
AUTH_ALLOWED_EMAILS=

# --- Database (Neon / ローカルは docker compose) ---
# DB ドライバ切替: neon=Neon(HTTP) / pg=素の PostgreSQL(TCP, ローカル docker)
# ローカルで docker の Postgres に繋いでアプリを動かすなら pg にする
DB_DRIVER=neon
# ランタイム用。neon なら Neon の pooled URL、pg なら docker の URL
DATABASE_URL=
# drizzle-kit マイグレーション用の direct(unpooled) URL
DATABASE_URL_UNPOOLED=
# ローカル docker compose を使う場合の例（両方同値でOK）:
# DATABASE_URL=postgresql://tottoku:tottoku@localhost:5432/tottoku
# DATABASE_URL_UNPOOLED=postgresql://tottoku:tottoku@localhost:5432/tottoku

# --- Amazon S3（書類の保存先） ---
# 認証は Vercel OIDC → IAM ロール assume。アクセスキーは持たない。
# ローカルは `vercel env pull .env.local` で VERCEL_OIDC_TOKEN を取得して実 S3 に繋ぐ。
# Vercel は AWS_REGION を実行リージョンで上書きするため必ず明示設定する。
AWS_REGION=ap-northeast-1
# assume する presign 用ロールの ARN（infra/cfn-tottoku-iam.yaml の出力 RoleArn）
AWS_ROLE_ARN=
# バケット名（prod=tottoku-documents-prod / dev=tottoku-documents-dev）
S3_BUCKET=
