# このファイルをコピーして .env.local を作成し、値を埋める（.env* はコミット禁止）
# 実際の秘密情報は Vercel の環境変数に設定する。

# --- Auth.js (Google ログイン) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# ログインを許可する家族のメール（カンマ区切り allowlist）
AUTH_ALLOWED_EMAILS=

# --- Database (サーバーレス PostgreSQL) ---
DATABASE_URL=

# --- Amazon S3 ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
